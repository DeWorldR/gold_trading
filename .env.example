# Gold Trading Bot — Configuration Template
# Copy this file to .env and fill in your real credentials.
# .env is .gitignored — never commit it.

# ─── MT5 / XM Broker (required for live trading) ──────────────────────
MT5_LOGIN=00000000
MT5_PASSWORD=your_mt5_password_here
MT5_SERVER=XMGlobal-MT5 2
MT5_SYMBOL=XAUUSD

# ─── Execution mode ───────────────────────────────────────────────────
# true = paper trade (no real orders sent); false = live trading via MT5
PAPER_TRADE=true

# ─── Telegram notifications (optional) ────────────────────────────────
# Bot token from @BotFather; chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Risk parameters (env-overridable; defaults in Config) ────────────
# Percent of account at risk per trade (default 1.0)
RISK_PER_TRADE_PCT=1.0
# Daily realized-loss limit in USD (default 300)
DAILY_LOSS_LIMIT=300
# Maximum concurrent open positions (default 1)
MAX_OPEN_POSITIONS=1

# ─── v11 — Live-mode gates ────────────────────────────────────────────
# Block entry when MT5 spread exceeds this USD value (default 0.60)
MAX_SPREAD_USD=0.60
# No new entries after this UTC hour on Fridays (default 17)
FRIDAY_CUTOFF_HOUR_UTC=17

# ─── v11.1 — Breakeven move ───────────────────────────────────────────
# R-multiple that triggers SL move to BE (default 1.0)
BE_TRIGGER_R=1.0
# Cushion in USD past entry when moving SL to BE (default 0.50)
BE_CUSHION_USD=0.50

# ─── v12 — Higher-timeframe filter + data hygiene ─────────────────────
# Set to "false" to disable 4H bias filter (kill switch)
HTF_BIAS_ENABLED=true
# Bars to fetch from MT5 per cycle (default 500)
MT5_FETCH_N_BARS=500
# Warn when MT5 close vs yfinance close differ by more than this USD (default 5.0; 0 disables)
DATA_DIVERGENCE_USD=5.0
